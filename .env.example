# Apple Notarization — Required for Gatekeeper-approved distribution
# Get an app-specific password at https://appleid.apple.com > Security > App-Specific Passwords
APPLE_ID=your@apple.id
APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=XXXXXXXXXX

# Code Signing — Set to the name of your Developer ID Application certificate
# Run: security find-identity -v -p codesigning
# Example: "Developer ID Application: Your Name (TEAMID)"
CSC_NAME=Developer ID Application: Your Name (TEAMID)

# --- BTMS (Basic Token Management System) ---
# Network preset for the BSV overlay network BTMS talks to.
# 'mainnet' | 'testnet' | 'local'
BTMS_NETWORK_PRESET=mainnet

# Optional: MessageBox host for token delivery. Leave blank for the
# default @bsv/message-box-client public host.
BTMS_MESSAGE_BOX_HOST=

# --- Veriff KYC ---
# https://dashboard.veriff.com → Integrations → API keys
# Sandbox: use Sandbox API key + Sandbox webhook secret.
VERIFF_API_KEY=your-veriff-api-key
VERIFF_API_URL=https://stationapi.veriff.com/v1/sessions

# Signing secret for BRC-KYC-Certificate issuance. A deterministic
# BSM signing key is derived from this secret. If left blank, the app
# will generate one on first run and store it locally at
# userData/kyc/signer.secret (mode 0o600). Never commit this value.
KYC_CERT_SIGNING_SECRET=
